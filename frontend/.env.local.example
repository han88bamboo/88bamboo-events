# ===========================================================================
# events-web local dev env (PATTERN-SPEC §B2.5, plan.md §9).
# Copy to `.env.local` (git-ignored) for running `next dev` OUTSIDE docker.
# When running via docker-compose, these values are injected by the compose
# `events-web` service instead — you do not need .env.local for that path.
#
# Production/Preview values live in the Vercel dashboard — there is NO
# .env.production file (plan §9).
# ===========================================================================

# Backend API base for the browser (host-mapped events-api port).
NEXT_PUBLIC_API_URL=http://localhost:5000

# Backend API base for SSR over the container network (compose service alias).
# Leave empty when NOT using docker (SSR then falls back to NEXT_PUBLIC_API_URL).
API_INTERNAL_URL=http://backend:5000

# The app's own public origin (used for canonical URLs / SEO), NOT for API calls.
# Local browse URL is http://localhost:8080/a/events.
NEXT_PUBLIC_BASE_URL=http://localhost:8080

# Stripe publishable (TEST) key for Stripe Elements (Phase 3).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Shopify App Proxy — server-only. false locally (no proxy exists); the shared
# secret is used only when verification is on.
SHOPIFY_PROXY_VERIFY=false
SHOPIFY_SHARED_SECRET=REPLACE_ME


#google maps api key
NEXT_PUBLIC_MAPS_BROWSER_KEY=paste_your_google_key_here
