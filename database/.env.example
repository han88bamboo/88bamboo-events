# database/.env.example — template for the git-ignored database/.env consumed by
# the docker-compose `db` (postgres:15-alpine) container. Copy to database/.env
# and fill in local values. Keep POSTGRES_* in sync with backend/.env
# (PATTERN-SPEC §A3.7).

# --- Postgres bootstrap (used by the official image to create the local DB) ---
POSTGRES_USER=events
POSTGRES_PASSWORD=events_local_pw
POSTGRES_DB=events

# --- Admin seed (read by database/seed-admin.sh on first boot) ---
# Never commit real values. Generate the hash with:
#   node database/make-admin-hash.js <ADMIN_EMAIL> <password>
# then paste the printed number below. Leave both blank to skip the admin seed
# (you can add the admin later — see database/README.md).
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
