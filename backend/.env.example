# ===========================================================================
# events-api configuration (PATTERN-SPEC §A4 / plan.md §9)
#
# ONE .env with two blocks. Keep the LOCAL block active for `docker compose up`;
# before building for deploy, comment the LOCAL block and uncomment PRODUCTION.
# Copy this file to `.env` and fill in the secret placeholders. NEVER commit real
# secrets — the working `.env` is git-ignored.
# ===========================================================================

# ---------------------------------------------------------------------------
# LOCAL LAUNCH  (active — comment out before deployment)
# ---------------------------------------------------------------------------
PURPOSE=development
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# Postgres — matches the docker-compose `db` service (database/.env)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=events
POSTGRES_USER=events
POSTGRES_PASSWORD=events_local_pw

# Stripe — TEST mode. Get sk_test_ from the Stripe dashboard; STRIPE_WEBHOOK_SECRET
# comes from `stripe listen --forward-to localhost:5000/<webhook path>`.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Shopify App Proxy — the shared secret is set (from the custom app) but UNUSED
# locally because SHOPIFY_PROXY_VERIFY=false (there is no proxy in front of us).
SHOPIFY_SHARED_SECRET=REPLACE_ME
SHOPIFY_PROXY_VERIFY=false

# Admin session signing key (Phase 4 — the §5.3 carve-out). Used to HMAC-sign the
# opaque admin session token issued at login and verified server-side on the
# approve/reject/capture/unpublish endpoints. If unset, the backend falls back to
# SHOPIFY_SHARED_SECRET, then to an INSECURE dev default (with a warning) so local
# dev works out of the box. Set a strong random value before deploying.
ADMIN_SESSION_SECRET=REPLACE_ME

# Public base for an approved listing's live URL (used only in the approval
# email). Local browse path; production is the apex proxy path.
PUBLIC_EVENT_BASE_URL=http://localhost:8080/a/events

# AWS / S3 (public image bucket, §A5). Leave the keys BLANK locally to use the
# on-disk upload stub (backend/uploads, served at /uploads/<key>) — the whole
# submission flow then runs with no AWS setup. Set real dev keys to target an
# actual dev bucket. S3_PUBLIC_BUCKET overrides the PURPOSE-based default bucket
# name (placeholder until the bucket is created in Phase 7).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
# S3_PUBLIC_BUCKET=88bamboo-events-images-dev

# Max uploaded image size in MB (submission abuse control, §8). Default 5.
MAX_IMAGE_MB=5

# Email — never send real mail locally (plan §9). With no MAIL_SERVER set, the
# mailer LOGS each message to the api console (zero infra). To capture mail in
# MailHog instead, run MailHog and set MAIL_SERVER=localhost, MAIL_PORT=1025.
# In production (PURPOSE=production) the mailer uses AWS SES v2 (boto3 sesv2).
SES_SENDER=Events - 88 Bamboo <events@88bamboo.co>
# MAIL_SERVER=
# MAIL_PORT=1025
# MAIL_USE_TLS=false
# MAIL_USERNAME=
# MAIL_PASSWORD=
# Admin new-submission alerts go to the active admin_users row; this env var is a
# fallback recipient when no admin is seeded locally.
ADMIN_NOTIFY_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Scheduled safety jobs (Phase 4B — APScheduler, plan §6/§8). Jobs run in ONE
# process: under gunicorn (compose) the single gevent worker owns them; under
# `python app.py` only the WERKZEUG_RUN_MAIN reloader child does.
# ---------------------------------------------------------------------------
# ENABLE_SCHEDULER=true    # set false to disable the background jobs (e.g. CLI/tests)
# DIGEST_HOUR_UTC=8        # hour (UTC) the daily pending-review digest is emailed

# ---------------------------------------------------------------------------
# PRODUCTION  (commented — uncomment before deployment, comment LOCAL above)
# ---------------------------------------------------------------------------
# PURPOSE=production
# FLASK_DEBUG=False
# HOST=0.0.0.0
# PORT=5000
#
# POSTGRES_HOST=<events-rds-endpoint>.ap-southeast-1.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_DB=events
# POSTGRES_USER=<prod-db-user>
# POSTGRES_PASSWORD=<prod-db-password>
#
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from the prod webhook endpoint
#
# SHOPIFY_SHARED_SECRET=<custom-app-shared-secret>
# SHOPIFY_PROXY_VERIFY=true
#
# ADMIN_SESSION_SECRET=<strong-random-secret>
# PUBLIC_EVENT_BASE_URL=https://www.88bamboo.co/a/events
#
# # In production, S3 uses the ECS task IAM role — leave the AWS keys UNSET (§A5).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
#
# SES_SENDER=Events - 88 Bamboo <events@88bamboo.co>
