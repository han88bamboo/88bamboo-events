# ===========================================================================
# events-api configuration (PATTERN-SPEC §A4 / plan.md §9)
#
# ONE .env with two blocks. Keep the LOCAL block active for `docker compose up`;
# before building for deploy, comment the LOCAL block and uncomment PRODUCTION.
# Copy this file to `.env` and fill in the secret placeholders. NEVER commit real
# secrets — the working `.env` is git-ignored.
# ===========================================================================

# ---------------------------------------------------------------------------
# LOCAL LAUNCH  (active — comment out before deployment)
# ---------------------------------------------------------------------------
PURPOSE=development
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# Postgres — matches the docker-compose `db` service (database/.env)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=events
POSTGRES_USER=events
POSTGRES_PASSWORD=events_local_pw

# Stripe — TEST mode. Get sk_test_ from the Stripe dashboard; STRIPE_WEBHOOK_SECRET
# comes from `stripe listen --forward-to localhost:5000/<webhook path>`.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Shopify App Proxy — the shared secret is set (from the custom app) but UNUSED
# locally because SHOPIFY_PROXY_VERIFY=false (there is no proxy in front of us).
SHOPIFY_SHARED_SECRET=REPLACE_ME
SHOPIFY_PROXY_VERIFY=false

# AWS / S3 (public image bucket, §A5). Leave the keys BLANK locally to use the
# on-disk upload stub (backend/uploads, served at /uploads/<key>) — the whole
# submission flow then runs with no AWS setup. Set real dev keys to target an
# actual dev bucket. S3_PUBLIC_BUCKET overrides the PURPOSE-based default bucket
# name (placeholder until the bucket is created in Phase 7).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
# S3_PUBLIC_BUCKET=88bamboo-events-images-dev

# Max uploaded image size in MB (submission abuse control, §8). Default 5.
MAX_IMAGE_MB=5

# Email — never send real mail locally. Use MailHog or a local mailer (plan §9).
SES_SENDER=events@88bamboo.co

# ---------------------------------------------------------------------------
# PRODUCTION  (commented — uncomment before deployment, comment LOCAL above)
# ---------------------------------------------------------------------------
# PURPOSE=production
# FLASK_DEBUG=False
# HOST=0.0.0.0
# PORT=5000
#
# POSTGRES_HOST=<events-rds-endpoint>.ap-southeast-1.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_DB=events
# POSTGRES_USER=<prod-db-user>
# POSTGRES_PASSWORD=<prod-db-password>
#
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from the prod webhook endpoint
#
# SHOPIFY_SHARED_SECRET=<custom-app-shared-secret>
# SHOPIFY_PROXY_VERIFY=true
#
# # In production, S3 uses the ECS task IAM role — leave the AWS keys UNSET (§A5).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
#
# SES_SENDER=events@88bamboo.co
